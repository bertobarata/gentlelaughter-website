{
  "name": "gentlelaughter-website",
  "version": "1.0.0",
  "description": "Gentle Laughter — produção, agenciamento, nove linhas. Site estático.",
  "private": true,
  "scripts": {
    "serve": "npx serve .",
    "purge": "npx purgecss --css css/styles.css --content '*.html' --output css/styles.purged.css",
    "build:pages": "node scripts/build-pages.mjs",
    "build:i18n": "node scripts/i18n-build.mjs",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:update": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.49.0",
    "purgecss": "^7.0.2"
  }
}
